# OHMEALS - Production Environment Variables Template
# Copy this file to .env and fill in the values

# Security
SECRET_KEY=your-super-secret-hex-key-here

# Database
# For SQLite (Dev): sqlite:///traiteur.db
# For PostgreSQL (Prod): postgresql://user:password@localhost/ohmeals
DATABASE_URL=sqlite:///traiteur.db

# Email Configuration (Gmail recommended)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Admin Configuration
ADMIN_USER=admin
ADMIN_EMAIL=admin@ohmeals.com
ADMIN_PASSWORD=change-me-immediately

# Flask Mode
FLASK_ENV=production
FLASK_APP=run.py
